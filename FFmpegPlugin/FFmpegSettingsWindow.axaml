<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FFmpegPlugin"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="200"
        x:Class="FFmpegPlugin.FFmpegSettingsWindow"
        x:DataType="vm:FFmpegSettingsViewModel"
        Title="FFmpeg Settings"
        Width="400" Height="200"
        CanResize="False">

    <Grid Margin="20" RowDefinitions="*,Auto">
        <StackPanel Grid.Row="0" Spacing="15">
            <CheckBox Content="ハードウェアデコードを有効にする"
                      IsChecked="{Binding HardwareDecodeEnabled}" />
            <StackPanel Spacing="5">
                <TextBlock Text="ハードウェアデコードAPI:" />
                <ComboBox ItemsSource="{Binding HwAccelApis}"
                          SelectedItem="{Binding SelectedHwAccelApi}"
                          MinWidth="200"
                          HorizontalAlignment="Left" />
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="10">
            <Button Content="キャンセル"
                    Command="{Binding CancelCommand}"
                    Width="80" />
            <Button Content="OK"
                    Command="{Binding SaveCommand}"
                    Width="80" />
        </StackPanel>
    </Grid>
</Window>